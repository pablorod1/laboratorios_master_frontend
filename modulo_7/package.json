{
  "name": "07-cloud-github-pages",
  "version": "1.0.0",
  "description": "GitHub Pages deployment laboratory",
  "type": "module",
  "scripts": {
    "start": "npm run start:dev",
    "start:dev": "vite --port 8080",
    "prebuild": "npm run type-check",
    "build": "vite build",
    "build:github-pages": "BASE_PATH=/laboratorios_master_frontend/ npm run build",
    "deploy:github-pages": "npm run build:github-pages && gh-pages -d dist",
    "preview": "vite preview --port 8080",
    "type-check": "tsc --noEmit",
    "type-check:watch": "npm run type-check -- --watch"
  },
  "imports": {
    "#*": "./src/*"
  },
  "author": "Lemoncode",
  "license": "MIT",
  "dependencies": {
    "@emotion/css": "^11.13.5",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^7.3.8",
    "formik": "^2.4.9",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "gh-pages": "^6.3.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
